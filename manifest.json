{
  "manifest_version": 3,
  "name": "SuperTab",
  "version": "1.0.0",
  "description": "Professional Chrome tab management with smart grouping, notes, and batch operations",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel",
    "contextMenus",
    "bookmarks"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "ui/sidebar/sidebar.html"
  },
  "action": {
    "default_title": "Open SuperTab",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "options_page": "ui/settings/settings.html",
  "web_accessible_resources": [
    {
      "resources": [
        "ui/rules/rules.html",
        "ui/rules/rules.css",
        "ui/rules/rules-manager.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
